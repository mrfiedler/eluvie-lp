{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.gpteng.co https://www.googletagmanager.com https://www.google-analytics.com https://plausible.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https: https://i.ytimg.com https://*.supabase.co https://www.eluvie.com; media-src 'self' https:; connect-src 'self' https://*.supabase.co https://www.google-analytics.com https://plausible.io wss://*.supabase.co; frame-src https://www.youtube.com https://www.youtube-nocookie.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/lovable-uploads/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(webp|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "</llms.txt>; rel=\"alternate\"; type=\"text/markdown\", </sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\""
        },
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "redirects": [
    { "source": "/blog/:slug(en-.+)", "destination": "/en/blog/:slug", "permanent": true },
    { "source": "/en/blog/:slug(pt-.+)", "destination": "/blog/:slug", "permanent": true },
    { "source": "/about", "destination": "/sobre-nos", "permanent": true },
    { "source": "/careers", "destination": "/carreiras", "permanent": true },
    { "source": "/diagnostic", "destination": "/diagnostico", "permanent": true },
    { "source": "/privacy", "destination": "/privacidade", "permanent": true },
    { "source": "/terms", "destination": "/termos", "permanent": true },
    { "source": "/hourly-rate-calculator", "destination": "/calculadora-valor-hora", "permanent": true },
    { "source": "/pricing-your-services", "destination": "/precificar-servicos", "permanent": true },
    { "source": "/en/calculadora-valor-hora", "destination": "/en/hourly-rate-calculator", "permanent": true },
    { "source": "/en/precificar-servicos", "destination": "/en/pricing-your-services", "permanent": true },
    { "source": "/coming-soon", "destination": "https://www.eluvie.app/", "permanent": true },
    { "source": "/em-breve", "destination": "https://www.eluvie.app/", "permanent": true },
    { "source": "/en/coming-soon", "destination": "https://www.eluvie.app/", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [
        { "type": "header", "key": "accept", "value": ".*text/markdown.*" }
      ],
      "destination": "/llms.txt"
    },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" }
  ]
}
